# GitHub Personal Access Token
# Get it from: github.com -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Required scopes: public_repo only
# Never commit the real .env file - only this .env.example
GITHUB_TOKEN=

# Optional: control how many repos the scraper fetches per search query (default 10)
SCRAPER_MAX_REPOS=10

# Optional: output directory for scraped raw files (default ./data/raw)
SCRAPER_OUTPUT_DIR=./data/raw

# Optional: output directory for parsed graph JSONs (default ./data/graphs)
GRAPHS_OUTPUT_DIR=./data/graphs

# Optional: output directory for synthetic OTel traces (default ./data/traces)
TRACES_OUTPUT_DIR=./data/traces

# Optional: output directory for trained model (default ./ghosttrace)
MODEL_OUTPUT_DIR=./ghosttrace
